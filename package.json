{
  "name": "mcp-tui-runner",
  "version": "0.1.0",
  "description": "MCP server for robust, OCR-free control of terminal UI applications",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test test/**/*.test.js",
    "test:watch": "node --test --watch test/**/*.test.js"
  },
  "keywords": ["mcp", "terminal", "tui", "automation", "ansi", "pty"],
  "author": "MCP TUI Runner Team",
  "license": "MIT",
  "dependencies": {
    "node-pty": "^1.0.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.18.2",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}